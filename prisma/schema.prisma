generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum BloodGroup {
  A_POSITIVE @map("A+")
  B_POSITIVE @map("B+")
  A_NEGATIVE @map("A-")
  B_NEGATIVE @map("B-")
  AB_POSITIVE @map("AB+")
  AB_NEGATIVE @map("AB-")
  O_POSITIVE @map("O+")
  O_NEGATIVE @map("O-")
}

enum RequestStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum Role {
  ADMIN
  VOLUNTEER
  USER
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum UrgencyLevel {
  NORMAL
  URGENT
  CRITICAL
}

model User {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  email            String   @unique
  password         String

  role             Role     @default(USER)

  bloodType        BloodGroup

  age              Int
  phoneNumber      String
  city             String

  bio              String?
  photo            String?

  lastDonationDate DateTime?

  isAvailable      Boolean  @default(true)

  latitude         Float?
  longitude        Float?

  status           UserStatus @default(ACTIVE)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  donatedRequests  Request[] @relation("DonorRequests")
  createdRequests  Request[] @relation("RequesterRequests")
}

model Request {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId

  bloodType        BloodGroup

  phoneNumber      String
  dateOfDonation   DateTime

  hospitalName     String
  hospitalAddress  String

  description      String?

  urgency          UrgencyLevel @default(NORMAL)

  requestStatus    RequestStatus @default(PENDING)

  donorId          String? @db.ObjectId
  requesterId      String  @db.ObjectId

  donor            User?  @relation("DonorRequests", fields: [donorId], references: [id])
  requester        User   @relation("RequesterRequests", fields: [requesterId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DonationEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  location    String
  date        DateTime
  description String?

  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  message   String
  isRead    Boolean  @default(false)

  createdAt DateTime @default(now())
}